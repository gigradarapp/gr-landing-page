---
import '../styles/global.css'

const appUrl = 'https://getbuzo.vercel.app/'
const waitlistUrl = 'https://gr-waitlist.vercel.app/'

const proofCells = [
  ['Ask naturally', 'Tell Buzo your vibe, timing, budget, area, and who you are going with.'],
  ['Compare credible picks', 'See Singapore events with venue, time, price context, category, image, and source.'],
  ['Decide and go', 'Open details, save a plan, share a pick, or come back when the weekend starts.'],
]

const fragments = [
  ['Instagram and TikTok', 'Good signals disappear quickly and rarely include enough detail to decide.'],
  ['Google and ticketing sites', 'Listings exist, but you still have to compare tabs, timing, distance, and vibe.'],
  ['Telegram and group chats', 'Plans move fast, but the useful context gets buried in conversation.'],
  ['Venue pages', 'Official pages know the event. They do not know what you are trying to do tonight.'],
]

const productSteps = [
  ['Intent', 'Ask for a night out by vibe, area, time, budget, genre, or group mood.'],
  ['Shortlist', 'Buzo narrows the choices to events that fit the moment instead of dumping every listing.'],
  ['Context', 'Check venue, timing, price, location, category, image, and source before you commit.'],
  ['Action', 'Open the app, save the event, plan the night, or share it with friends.'],
]

const trustNotes = [
  ['Less stale discovery', 'Buzo is built around fresh event data, source links, and structured event fields.'],
  ['Taste-aware search', 'Recommendations can use your stated preferences instead of forcing keyword search.'],
  ['Singapore-first density', 'The first market is narrow by design: dense, social, nightlife-heavy, and testable.'],
]

const decisionRows = [
  ['01', 'What is good tonight?', 'Start with a high-intent question instead of browsing every platform.'],
  ['02', 'Is this worth the trip?', 'Use time, venue, price, distance, category, and source context to judge faster.'],
  ['03', 'Does this fit my vibe?', 'Filter around music taste, energy level, group mood, and location.'],
  ['04', 'Can I act on it?', 'Move from discovery to details, saves, sharing, and planning without restarting the search.'],
]

const founders = [
  {
    name: 'Clarence Chan',
    role: 'Co-Founder & CEO',
    lane: 'Nightlife, growth, partnerships',
    image: '/assets/media/founder.jpg',
    alt: 'Clarence Chan portrait',
    bio: 'Live events and nightlife operator leading market insight, venue relationships, growth, and demand-side strategy.',
    signals: ['Nightlife operator', 'Venue network', 'Growth'],
  },
  {
    name: 'Sayyid Khan',
    role: 'Co-Founder & CTO',
    lane: 'Product, AI, architecture',
    image: '/assets/media/sayyid.jpg',
    alt: 'Sayyid Khan portrait',
    bio: 'Full-stack AI engineer leading product architecture, agentic AI execution, payments, and scalable systems.',
    signals: ['Agentic AI', 'Full-stack systems', 'Scalability'],
  },
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Buzo is an AI nightlife concierge for Singapore that helps people choose credible events worth going to tonight."
    />
    <meta name="theme-color" content="#070708" />
    <link rel="icon" href="/favicon.ico" />
    <title>Buzo — Find a credible night out faster</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="nav" aria-label="Primary navigation">
        <div class="nav-inner">
          <a class="brand" href="/" aria-label="Buzo home">
            <img src="/assets/logo/b-logo.svg" alt="" width="34" height="34" />
            <span>Buzo</span>
          </a>
          <nav class="nav-links" aria-label="Page sections">
            <a href="#product">Product</a>
            <a href="#how">How it works</a>
            <a href="#trust">Trust</a>
            <a href="/company">Company</a>
          </nav>
          <a class="button button-primary" href={appUrl}>Try the app</a>
        </div>
      </header>

      <main>
        <section class="section hero consumer-hero" id="top">
          <div class="hero-copy">
            <h1>
              <span class="hero-line">Find a</span>
              <span class="hero-line">credible night</span>
              <span class="hero-line">out <span class="hero-accent">faster.</span></span>
            </h1>
            <p class="hero-sub">
              Buzo is an AI nightlife concierge for Singapore. Tell it your vibe, area, and timing, and
              it helps you choose events worth going to tonight.
            </p>
            <div class="hero-actions" aria-label="Primary actions">
              <a class="button button-primary" href={appUrl}>Try the app</a>
              <a class="button button-secondary" href={waitlistUrl}>Join waitlist</a>
            </div>
            <div class="hero-proof" aria-label="How Buzo helps">
              {proofCells.map(([title, body]) => (
                <div class="proof-cell">
                  <strong>{title}</strong>
                  <span>{body}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="hero-visual" aria-label="Buzo app preview">
            <div class="signal-field">
              <div class="signal-map">
                <div class="route-line"></div>
                <span class="pin pin-1"></span>
                <span class="pin pin-2"></span>
                <span class="pin pin-3"></span>
              </div>
            </div>

            <div class="signal-card signal-card-one">
              <small>Ask Buzo</small>
              <strong>“Tonight, central, good energy.”</strong>
              <p>Buzo turns vague intent into a shortlist you can actually compare.</p>
            </div>

            <div class="signal-card signal-card-two">
              <small>Event context</small>
              <strong>Venue, time, price, source.</strong>
              <p>The goal is confidence, not another infinite list of events.</p>
            </div>

            <div class="phone">
              <div class="phone-screen">
                <div class="phone-top">
                  <span>Ask Buzo</span>
                  <span>Singapore</span>
                </div>
                <div class="video-frame">
                  <video src="/assets/media/demo.mp4" autoplay muted loop playsinline preload="metadata"></video>
                  <div class="phone-panel">
                    <strong>Pick tonight with context.</strong>
                    <span>Fresh events, useful filters, and AI recommendations built for real plans.</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="section" aria-labelledby="problem-title">
          <div class="section-head">
            <div>
              <p class="section-kicker">The problem</p>
              <h2 class="section-title" id="problem-title">Going out should not require ten tabs.</h2>
            </div>
            <p class="section-copy">
              Event discovery is scattered across feeds, search, venue pages, ticketing sites, and private
              chats. Buzo starts from the real job: help me decide what is worth going to tonight.
            </p>
          </div>

          <div class="split-proof">
            <div class="problem-panel">
              <div class="fragment-list">
                {fragments.map(([title, body]) => (
                  <article class="fragment">
                    <strong>{title}</strong>
                    <span>{body}</span>
                  </article>
                ))}
              </div>
            </div>
            <aside class="quote-panel">
              <blockquote>People do not lack listings. They lack confidence.</blockquote>
              <p>
                The best answer is not more events. It is the few events that fit the night, with enough
                context to act.
              </p>
            </aside>
          </div>
        </section>

        <section class="section" id="product" aria-labelledby="product-title">
          <div class="section-head">
            <div>
              <p class="section-kicker">Product</p>
              <h2 class="section-title" id="product-title">A nightlife concierge, not another event board.</h2>
            </div>
            <p class="section-copy">
              Buzo combines a Singapore event catalog, an AI recommendation layer, and planning surfaces so
              users can move from vague intent to a confident option.
            </p>
          </div>

          <div class="system-grid">
            <div class="loop" aria-label="Buzo decision loop">
              <div class="loop-center"><strong>Tonight's decision</strong></div>
              {productSteps.map(([title, body], index) => (
                <div class={`loop-step loop-step-${['one', 'two', 'three', 'four'][index]}`} data-step={String(index + 1)}>
                  <strong>{title}</strong>
                  <span>{body}</span>
                </div>
              ))}
            </div>

            <div class="product-copy">
              <article class="system-note">
                <strong>Discover</strong>
                <p>Browse Singapore events with useful details instead of scattered fragments.</p>
              </article>
              <article class="system-note">
                <strong>Ask Buzo</strong>
                <p>Use natural language when you know the mood but not the venue.</p>
              </article>
              <article class="system-note">
                <strong>Plan</strong>
                <p>Save and compare events so the decision survives the group chat.</p>
              </article>
            </div>
          </div>
        </section>

        <div class="market-band" id="how">
          <section class="section" aria-labelledby="how-title">
            <div class="section-head">
              <div>
                <p class="section-kicker">How it works</p>
                <h2 class="section-title" id="how-title">Start with the question people already ask.</h2>
              </div>
              <p class="section-copy">
                “What should we do tonight?” is not a search query. It is a decision under time pressure.
                Buzo is designed around that moment.
              </p>
            </div>

            <div class="wedge-grid">
              <div class="city-panel">
                <div>
                  <h3>Singapore nights are dense, fast, and social.</h3>
                  <p>
                    Buzo starts where the pain is practical: people decide late, compare imperfect sources,
                    and need enough confidence to leave the house.
                  </p>
                </div>
                <div class="city-map" aria-hidden="true">
                  <span class="city-node"></span>
                  <span class="city-node"></span>
                  <span class="city-node"></span>
                </div>
              </div>

              <div class="model-list">
                {decisionRows.map(([index, title, body]) => (
                  <article class="model-row">
                    <span class="model-index">{index}</span>
                    <div>
                      <strong>{title}</strong>
                      <span>{body}</span>
                    </div>
                  </article>
                ))}
              </div>
            </div>
          </section>
        </div>

        <section class="section" id="trust" aria-labelledby="trust-title">
          <div class="section-head">
            <div>
              <p class="section-kicker">Trust</p>
              <h2 class="section-title" id="trust-title">Built around context, not hype.</h2>
            </div>
            <p class="section-copy">
              Buzo earns user trust by making recommendations explainable: where the event is, when it is
              happening, what it costs, what kind of event it is, and where the listing came from.
            </p>
          </div>

          <div class="proof-grid">
            {trustNotes.map(([title, body]) => (
              <article class="proof-tile">
                <strong>{title}</strong>
                <p>{body}</p>
              </article>
            ))}
            <article class="proof-tile proof-tile-accent">
              <strong>Want the company story?</strong>
              <p>Business model, product architecture, and validation plan are available separately.</p>
              <a class="proof-link" href="/company">Open company page</a>
            </article>
          </div>
        </section>

        <section class="section team-section" id="team" aria-labelledby="team-title">
          <div class="team-copy">
            <p class="section-kicker">Team</p>
            <h2 id="team-title">Nightlife operator edge plus AI execution.</h2>
            <p>
              Buzo is led by two active co-founders combining events-market access, product engineering,
              AI systems, and financial discipline.
            </p>
          </div>
          <div class="founder-grid" aria-label="Buzo founder roles">
            {founders.map(({ name, role, lane, image, alt, bio, signals }) => (
              <article class="founder-card">
                <div class="founder-portrait">
                  <img src={image} alt={alt} width="800" height="800" loading="lazy" />
                </div>
                <div class="founder-details">
                  <span class="founder-role">{role}</span>
                  <h3>{name}</h3>
                  <p class="founder-lane">{lane}</p>
                  <p>{bio}</p>
                  <div class="founder-signals" aria-label={`${name} founder strengths`}>
                    {signals.map((signal) => <span>{signal}</span>)}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="section final-cta" aria-labelledby="cta-title">
          <div class="cta-panel">
            <div>
              <h2 id="cta-title">Stop guessing where to go tonight.</h2>
              <p>
                Try the live app, join the waitlist, or read the company page for Buzo’s product and
                business model.
              </p>
            </div>
            <div class="cta-actions">
              <a class="button button-primary" href={appUrl}>Try the app</a>
              <a class="button button-secondary" href={waitlistUrl}>Join waitlist</a>
              <a class="button button-secondary" href="/company">Company</a>
            </div>
          </div>
        </section>
      </main>

      <footer class="footer">
        <div class="footer-inner">
          <span>© 2026 Buzo. Built from Singapore.</span>
          <div class="footer-links">
            <a href={appUrl}>App</a>
            <a href={waitlistUrl}>Waitlist</a>
            <a href="/company">Company</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
